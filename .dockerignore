# Keep the build context small and, more importantly, keep secrets out of it.
# Anything listed here is never sent to the daemon and cannot end up in a layer.

node_modules
.next
out
build

# secrets — these are supplied at runtime, never baked into the image
.env
.env.*
!.env.example

.git
.gitignore

# tests and their artefacts are not needed to build the app
tests
test-results
playwright-report
blob-report
playwright/.cache
playwright.config.ts
vitest.config.mts

# local tooling noise
*.tsbuildinfo
npm-debug.log*
.DS_Store
README.md
instruction.md
CLAUDE.md
AGENTS.md
Dockerfile
.dockerignore
docker-compose.yml
