# ---------------------------------------------------------------------------
# Copy to .env.local and fill in. Every value here is optional: the site builds
# and renders completely without any of them.
# ---------------------------------------------------------------------------

# Absolute origin of the deployed site. Used for canonical URLs, Open Graph tags,
# the sitemap and robots.txt. Falls back to Vercel's production domain, then to
# http://localhost:3000. Set this before deploying anywhere else.
NEXT_PUBLIC_SITE_URL="https://your-domain.example"

# --- Contact form ----------------------------------------------------------
# Without these the form validates input and then reports that it is not
# configured; it never crashes the page or the build.

# API key from https://resend.com
RESEND_API_KEY=""

# Where contact messages are delivered.
CONTACT_TO_EMAIL="you@example.com"

# Verified sender. Resend's onboarding@resend.dev works for testing; use a
# domain you have verified for production.
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"

# --- Docker Compose only ---------------------------------------------------
# Name of the existing Docker network the reverse proxy is attached to, so the
# container can be reached by name without publishing a port. Check it with:
#   docker inspect <proxy-container> --format '{{json .NetworkSettings.Networks}}'
PROXY_NETWORK="notmybeer_default"

# --- Optional: live GitHub numbers -----------------------------------------
# The site ships a checked-in snapshot of the profile and repository data, so it
# is fully populated with no token. If a token is present, star counts and last
# push dates are refreshed at build time; any failure silently falls back to the
# snapshot. A token with no scopes is enough — it only reads public data.
GITHUB_TOKEN=""
